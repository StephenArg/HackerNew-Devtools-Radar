DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hn_devtools_radar?schema=public"
OPENAI_API_KEY=
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
MOCK_MODE=false
RELEVANCE_USE_EMBEDDINGS=false
# Rate limits — set to your OpenAI tier (free tiers are often much lower)
OPENAI_EMBEDDING_RPM=100
OPENAI_CHAT_RPM=10
OPENAI_EMBEDDING_BATCH_SIZE=64
# Minimum ms between consecutive calls (defaults to 60000 / RPM if unset)
# OPENAI_EMBEDDING_MIN_INTERVAL_MS=600
# OPENAI_CHAT_MIN_INTERVAL_MS=6000
# Pause after retrieval embeddings before the batched chat call (defaults to chat interval)
# OPENAI_EMBEDDING_TO_CHAT_DELAY_MS=6000
# Max chunks included in report/judge prompts (lower = fewer TPM spikes)
OPENAI_REPORT_MAX_CHUNKS=16
# After a quota error, skip OpenAI for this long (ms) then auto-retry. Explicit
# generate actions always probe the live API regardless of this cooldown.
OPENAI_QUOTA_COOLDOWN_MS=60000
